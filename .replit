modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5904
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3002







[env]
PORT = "5000"

[deployment]
deploymentTarget = "gce"
build = ["npm", "run", "build"]
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo Mobile"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-crash-reporter-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f 'tsx server/index.ts' 2>/dev/null; fuser -k 5000/tcp 2>/dev/null; sleep 1; npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Expo Mobile"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && pkill -f 'expo start' 2>/dev/null; pkill -f metro 2>/dev/null; sleep 1; npm install 2>&1; REACT_NATIVE_PACKAGER_HOSTNAME=163cfc20-e221-41ad-b2c3-67afe2df4e33-00-15yrg27byh3aa.spock.replit.dev npx expo start --port 8080 --clear"
waitForPort = 8080

[[workflows.workflow]]
name = "mobile-crash-reporter-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && node ../node_modules/.bin/jest --config jest.config.js --no-coverage"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vitest run --config vitest.config.ts"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "MOCKUP_JS"
mockupState = "FULLSTACK"
integrations = ["javascript_object_storage:2.0.0"]

[userenv]

[userenv.shared]
EXPO_PUBLIC_API_URL = "https://163cfc20-e221-41ad-b2c3-67afe2df4e33-00-15yrg27byh3aa.spock.replit.dev"
JWT_SECRET = "47bcf839cffb697426bf249ee7f5784a184f8d146de1d99a208927a5c4286024"
SHARE_BASE_URL = "https://trybubble.io"
RATE_LIMIT_AUTH_MAX = "10"
RATE_LIMIT_AUTH_WINDOW_MIN = "15"
RATE_LIMIT_SEND_MAX = "5"
RATE_LIMIT_SEND_WINDOW_MIN = "60"
EXPO_PUBLIC_COMETCHAT_APP_ID = "1673948f1ffba3646"
EXPO_PUBLIC_COMETCHAT_REGION = "us"

[userenv.development]

[userenv.production]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
