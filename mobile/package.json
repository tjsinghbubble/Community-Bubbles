    "@react-navigation/native": "^7.0.19",
    "@react-navigation/native-stack": "^7.2.9",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.60.5",
    "babel-preset-expo": "~55.0.8",
    "date-fns": "^3.6.0",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.17",
    "expo-document-picker": "~55.0.13",
