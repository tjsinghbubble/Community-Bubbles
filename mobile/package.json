{
  "name": "bubble-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "node ../node_modules/.bin/jest --config jest.config.js",
    "version:bump": "node scripts/bump-version.js",
