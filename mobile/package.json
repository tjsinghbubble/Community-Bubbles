    "@react-navigation/native": "^7.0.19",
    "@react-navigation/native-stack": "^7.2.9",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.60.5",
    "babel-preset-expo": "~54.0.10",
    "date-fns": "^3.6.0",
    "expo": "~55.0.0",
    "expo-asset": "~12.0.12",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
