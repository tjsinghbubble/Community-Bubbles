{
  "name": "rest-express",
  "version": "1.9.2",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:client": "vite dev --port 5000",
    "dev": "NODE_ENV=development tsx server/index.ts",
    "dev:local": "node scripts/qr.mjs & NODE_ENV=development node --env-file=.env --import=tsx/esm server/index.ts",
    "build": "tsx scripts/build.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "db:push:local": "node --env-file=.env ./node_modules/.bin/drizzle-kit push",
    "db:reset:local": "node --env-file=.env scripts/db-reset.mjs && npm run db:push:local",
    "db:seed-test:local": "node --env-file=.env --import=tsx/esm scripts/seed-test-data.ts",
    "db:reset-full:local": "npm run db:reset:local && npm run db:seed-test:local",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:ios": "npm --prefix mobile run start -- --ios",
    "mobile:android": "npm --prefix mobile run start -- --android",
    "mobile:build:ios-sim": "npm --prefix mobile run ios",
    "mobile:build:android-emu": "npm --prefix mobile run android",
    "test:e2e": "maestro test -e APP_ID=com.bubble.mobile -e METRO_HOST=metro_host .maestro/native/",
    "test:e2e:expo": "maestro test -e APP_ID=host.exp.Exponent .maestro/",
    "test:e2e:web": "maestro test --platform web -e APP_ID=http://metro_host:8081 -e METRO_HOST=metro_host .maestro/web/",
    "test:e2e:web-mobile": "maestro test -e APP_ID=com.apple.mobilesafari -e METRO_HOST=metro_host .maestro/web/",
    "qr": "node scripts/qr.mjs",
    "prepare": "husky",
    "type-check": "tsc --noEmit && (cd mobile && tsc --noEmit)",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:e2e:prod": "playwright test --grep @prod-safe"
  },
